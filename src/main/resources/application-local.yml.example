# 本地开发专用配置模板
# 使用方法：
# 1. 复制本文件为 application-local.yml
# 2. 将下面的数据库账号和密码替换为你自己的本地配置
# 3. application-local.yml 已在 .gitignore 中忽略，不会被提交到仓库

spring:
  datasource:
    # 请修改为你自己的本地数据库地址
    url: jdbc:mysql://localhost:3306/therepairsystem?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
    # 请修改为你自己的本地数据库用户名
    username: your_local_username
    # 请修改为你自己的本地数据库密码
    password: your_local_password
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      # 开发环境可使用 update，生产环境建议改为 none 或通过迁移工具管理
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

# 工单附件存储配置（本地开发环境）
file:
  upload:
    # 可选：LOCAL / MINIO
    storage-provider: LOCAL
    # 建议使用本地绝对路径，避免因工作目录变化导致找不到文件
    # Windows示例: D:/ProjectMe/TheRepairSystemBackend/uploads
    # macOS/Linux示例: /Users/yourname/therepairsystem/uploads
    base-path: uploads
    # 单文件最大大小（10MB）
    max-file-size-bytes: 10485760
    # 允许内容类型
    allowed-content-types: image/jpeg,image/png,image/webp
    # MinIO 配置（当 storage-provider=MINIO 生效）
    minio:
      enabled: false
      endpoint: http://localhost:9000
      access-key: root
      secret-key: root12345
      bucket: repair-attachments
      auto-create-bucket: true

# AI 服务本地配置（请填写你自己的 key）
siliconflow:
  # SiliconFlow API URL
  api-url: https://api.siliconflow.cn/v1/chat/completions
  # 请填写你自己的 API Key（不要提交到仓库）
  api-key: your_local_siliconflow_api_key
  # 默认模型，可按需替换
  model: deepseek-ai/DeepSeek-V3.2
